<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.matrixone-driver-integration</id>
    <name>MatrixOne Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides MatrixOne JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：MatrixOrigin
<br>超融合引擎、 异构云原生、 极致的性能
<br>简介：MatrixOne 是矩阵起源研发的一款新一代超融合异构云原生数据库，它通过简化的分布式数据库引擎支持跨多个数据中心、云、边缘和其他异构基础架构的事务、分析和流工作负载。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="MATRIXONE" instance="plus.wcj.jetbrains.plugins.matrixone.MatrixOneDatabaseDbms.MATRIXONE"/>
        <extensionFallback dbms="MATRIXONE" fallbackDbms="MYSQL"/>
        <addToHSet item="MATRIXONE" set="MYSQL_LIKE"/>
        <addToHSet item="MATRIXONE" set="PSEUDO_SUPPORTED"/>

        <dbms id="MATRIXONE_MYSQL" instance="plus.wcj.jetbrains.plugins.matrixone.MatrixOneDatabaseDbms.MATRIXONE_MYSQL"/>
        <extensionFallback dbms="MATRIXONE_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="MATRIXONE_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="MATRIXONE_MYSQL" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
