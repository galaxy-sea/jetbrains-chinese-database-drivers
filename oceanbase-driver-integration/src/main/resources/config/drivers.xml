<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="oceanbase" name="OceanBase" icon="/icons/driversIcon.svg" dialect="GenericSQL" driver-class="com.oceanbase.jdbc.Driver">
    <url-template name="default" template="jdbc:oceanbase://{host::localhost}[:{port::2881}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="OceanBase JDBC Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
</drivers>
