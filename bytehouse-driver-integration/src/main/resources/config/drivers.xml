<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="bytehouse" name="ByteHouse" icon="/icons/driversIcon.svg" dialect="ClickHouse" forced-dbms="BYTEHOUSE" driver-class="com.bytehouse.jdbc.ByteHouseDriver" group-with="bytehouse">
    <url-template name="default" template="jdbc:bytehouse://{host::localhost}[:{port::19000}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="ByteHouse Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
  <driver id="bytehouse-clickhouse" name="ByteHouse (ClickHouse)" icon="/icons/driversIcon.svg" forced-dbms="BYTEHOUSE_CLICKHOUSE" based-on="clickhouse" group-with="bytehouse">
    <remarks>ByteHouse</remarks>
  </driver>
  <driver id="bytehouse-mysql" name="ByteHouse (MySQL)" icon="/icons/driversIcon.svg" forced-dbms="BYTEHOUSE_MYSQL" based-on="mysql.8" group-with="bytehouse">
    <remarks>ByteHouse</remarks>
  </driver>
</drivers>
