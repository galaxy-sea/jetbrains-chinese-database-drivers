<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.cnosdb-driver-integration</id>
    <name>CnosDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides CnosDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="CNOSDB" instance="plus.wcj.jetbrains.plugins.cnosdb.CnosDBDatabaseDbms.CNOSDB"/>
        <extensionFallback dbms="CNOSDB" fallbackDbms="UNKNOWN"/>
        <addToHSet item="CNOSDB" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
