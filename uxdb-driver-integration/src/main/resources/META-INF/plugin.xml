<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.uxdb-driver-integration</id>
    <name>UXDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides UXDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：北京优炫数据库股份有限公司（优炫数据）
<br>多写多读、 平滑迁移、 多模态融合、 极速OLAP、 HTAP
<br>简介：优炫数据库（UXDB）是由北京优炫数据库股份有限公司研发的企业级数据库产品。产品以可靠、安全、多模融合和智能驱动为核心特性，通过统一架构支撑全场景的数据管理、开发与业务洞察，致力于从数据管理、数据科学到生态协作的持续演进，打造面向未来数智产业的数据底座。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="UXDB" instance="plus.wcj.jetbrains.plugins.uxdb.UXDBDatabaseDbms.UXDB"/>
        <extensionFallback dbms="UXDB" fallbackDbms="POSTGRES"/>
        <addToHSet item="UXDB" set="POSTGRES_LIKE"/>
        <addToHSet item="UXDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="UXDB_ORACLE" instance="plus.wcj.jetbrains.plugins.uxdb.UXDBDatabaseDbms.UXDB_ORACLE"/>
        <extensionFallback dbms="UXDB_ORACLE" fallbackDbms="ORACLE"/>
        <addToHSet item="UXDB_ORACLE" set="ORACLE_LIKE"/>
        <addToHSet item="UXDB_ORACLE" set="PSEUDO_SUPPORTED"/>

        <dbms id="UXDB_MYSQL" instance="plus.wcj.jetbrains.plugins.uxdb.UXDBDatabaseDbms.UXDB_MYSQL"/>
        <extensionFallback dbms="UXDB_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="UXDB_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="UXDB_MYSQL" set="PSEUDO_SUPPORTED"/>

        <dbms id="UXDB_POSTGRES" instance="plus.wcj.jetbrains.plugins.uxdb.UXDBDatabaseDbms.UXDB_POSTGRES"/>
        <extensionFallback dbms="UXDB_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="UXDB_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="UXDB_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
