<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.argodb-driver-integration</id>
    <name>ArgoDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides ArgoDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：星环科技
<br>完整的SQL支持、 高效计算引擎、 新硬件支持、 多模型支持、 联邦计算
<br>简介：Transwarp ArgoDB是星环全新推出的一款分布式闪存数据库产品。它可以替代 Hadoop + MPP 混合架构，一站式满足企业对大数据平台的各种诉求。让企业更高效地使用大数据平台，从而更好地利用大数据的商业价值。
    <br>QQ群：737639828
    <br>bug反馈：https://github.com/galaxy-sea/jetbrains-chinese-database-drivers/issues
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="ARGODB" instance="plus.wcj.jetbrains.plugins.argodb.ArgoDBDatabaseDbms.ARGODB"/>
        <extensionFallback dbms="ARGODB" fallbackDbms="HIVE"/>
        <addToHSet item="ARGODB" set="PSEUDO_SUPPORTED"/>

        <dbms id="ARGODB_HIVE" instance="plus.wcj.jetbrains.plugins.argodb.ArgoDBDatabaseDbms.ARGODB_HIVE"/>
        <extensionFallback dbms="ARGODB_HIVE" fallbackDbms="HIVE"/>
        <addToHSet item="ARGODB_HIVE" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
