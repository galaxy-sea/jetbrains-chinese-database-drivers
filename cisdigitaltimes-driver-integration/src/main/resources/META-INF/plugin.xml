<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.cisdigitaltimes-driver-integration</id>
    <name>CISDigitalTimeS Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides CISDigitalTimeS JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="CISDIGITALTIMES" instance="plus.wcj.jetbrains.plugins.cisdigitaltimes.CISDigitalTimeSDatabaseDbms.CISDIGITALTIMES"/>
        <extensionFallback dbms="CISDIGITALTIMES" fallbackDbms="UNKNOWN"/>
        <addToHSet item="CISDIGITALTIMES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
