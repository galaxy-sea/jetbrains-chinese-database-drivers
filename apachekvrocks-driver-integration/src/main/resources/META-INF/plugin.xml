<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.apachekvrocks-driver-integration</id>
    <name>Apache Kvrocks Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides Apache Kvrocks JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="APACHEKVROCKS" instance="plus.wcj.jetbrains.plugins.apachekvrocks.ApacheKvrocksDatabaseDbms.APACHEKVROCKS"/>
        <extensionFallback dbms="APACHEKVROCKS" fallbackDbms="REDIS"/>
        <addToHSet item="APACHEKVROCKS" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
