<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="lindorm" name="Lindorm" icon="/icons/driversIcon.svg" dialect="MySQL" forced-dbms="LINDORM" driver-class="com.aliyun.lindorm.table.client.Driver" group-with="lindorm">
    <url-template name="default" template="jdbc:lindorm:table//{host::localhost}[:{port::30060}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <url-template name="TSDB" template="jdbc:lindorm:tsdb//{host::localhost}[:{port::8242}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <url-template name="Search" template="jdbc:lindorm:search//{host::localhost}[:{port::30070}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="Lindorm Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>


  <driver id="lindorm-mysql" name="Lindorm (MySQL)" icon="/icons/driversIcon.svg" forced-dbms="LINDORM_MYSQL" based-on="mysql.8" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
  <driver id="lindorm-cassandra" name="Lindorm (Cassandra)" icon="/icons/driversIcon.svg" forced-dbms="LINDORM_CASSANDRA" based-on="cassandra" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
  <driver id="lindorm-hive" name="Lindorm (Hive)" icon="/icons/driversIcon.svg" forced-dbms="LINDORM_HIVE" based-on="hive" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
</drivers>
