<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="lindorm" name="Lindorm" dialect="MySQL" forced-dbms="LINDORM" driver-class="com.aliyun.lindorm.table.client.Driver" group-with="lindorm">
    <url-template name="default" template="jdbc:lindorm:table:url=http://{host::localhost}[:{port::30060}][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="Lindorm Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
  <driver id="lindorm-tsdb" name="Lindorm TSDB" dialect="MySQL" forced-dbms="LINDORM" driver-class="com.aliyun.lindorm.tsdb.client.Driver" group-with="lindorm">
    <url-template name="default" template="jdbc:lindorm:tsdb:url=http://{host::localhost}[:{port::8242}][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="Lindorm Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
  <driver id="lindorm-search" name="Lindorm Search" dialect="MySQL" forced-dbms="LINDORM" driver-class="com.aliyun.lindorm.search.client.Driver" group-with="lindorm">
    <url-template name="default" template="jdbc:lindorm:search:url=http://{host::localhost}[:{port::30070}][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="Lindorm Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>


  <driver id="lindorm-mysql" name="Lindorm (MySQL)" forced-dbms="LINDORM_MYSQL" based-on="mysql.8" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
  <driver id="lindorm-cassandra" name="Lindorm (Cassandra)" forced-dbms="LINDORM_CASSANDRA" based-on="cassandra" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
  <driver id="lindorm-hive" name="Lindorm (Hive)" forced-dbms="LINDORM_HIVE" based-on="hive" group-with="lindorm">
    <remarks>Lindorm</remarks>
  </driver>
</drivers>
