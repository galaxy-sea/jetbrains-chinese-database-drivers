<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.klustron-driver-integration</id>
    <name>Klustron Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides Klustron JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：泽拓科技
<br>弹性伸缩、 兼容MySQL、 兼容PostgreSQL、 极致性能、 极致安全、 用户友好
<br>简介：Klustron（旧名称：KunlunBase）是泽拓科技研发的一款国产的关系型数据库，作为 NewSQL 的一个代表，可处理 TB 和 PB 级别海量数据， 并且具有高性能，高可扩展性，高可用性和具有完备容灾能力。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="KLUSTRON" instance="plus.wcj.jetbrains.plugins.klustron.KlustronDatabaseDbms.KLUSTRON"/>
        <extensionFallback dbms="KLUSTRON" fallbackDbms="POSTGRES"/>
        <addToHSet item="KLUSTRON" set="POSTGRES_LIKE"/>
        <addToHSet item="KLUSTRON" set="PSEUDO_SUPPORTED"/>

        <dbms id="KLUSTRON_POSTGRES" instance="plus.wcj.jetbrains.plugins.klustron.KlustronDatabaseDbms.KLUSTRON_POSTGRES"/>
        <extensionFallback dbms="KLUSTRON_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="KLUSTRON_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="KLUSTRON_POSTGRES" set="PSEUDO_SUPPORTED"/>

        <dbms id="KLUSTRON_MYSQL" instance="plus.wcj.jetbrains.plugins.klustron.KlustronDatabaseDbms.KLUSTRON_MYSQL"/>
        <extensionFallback dbms="KLUSTRON_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="KLUSTRON_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="KLUSTRON_MYSQL" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
