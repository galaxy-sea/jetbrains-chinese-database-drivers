<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.indb-driver-integration</id>
    <name>InDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides InDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：浪潮云
<br>兼容MySQL、 兼容Oracle、 全密态、 安全审计
<br>简介：浪潮云岳数据库 InDB 是基于openGauss内核增强提升，推出的一款稳定、可靠的云原生关系型数据库，高度兼容MySQL、Oracle协议，支持全密态、安全审计、备份恢复、多维度监控、弹性伸缩、智能运维等关键能力，可作为政企应用关系型数据存储的坚实底座。
    <br>QQ群：737639828
    <br>bug反馈：https://github.com/galaxy-sea/jetbrains-chinese-database-drivers/issues
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="INDB" instance="plus.wcj.jetbrains.plugins.indb.InDBDatabaseDbms.INDB"/>
        <extensionFallback dbms="INDB" fallbackDbms="POSTGRES"/>
        <addToHSet item="INDB" set="POSTGRES_LIKE"/>
        <addToHSet item="INDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="INDB_POSTGRES" instance="plus.wcj.jetbrains.plugins.indb.InDBDatabaseDbms.INDB_POSTGRES"/>
        <extensionFallback dbms="INDB_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="INDB_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="INDB_POSTGRES" set="PSEUDO_SUPPORTED"/>

        <dbms id="INDB_MYSQL" instance="plus.wcj.jetbrains.plugins.indb.InDBDatabaseDbms.INDB_MYSQL"/>
        <extensionFallback dbms="INDB_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="INDB_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="INDB_MYSQL" set="PSEUDO_SUPPORTED"/>

        <dbms id="INDB_ORACLE" instance="plus.wcj.jetbrains.plugins.indb.InDBDatabaseDbms.INDB_ORACLE"/>
        <extensionFallback dbms="INDB_ORACLE" fallbackDbms="ORACLE"/>
        <addToHSet item="INDB_ORACLE" set="ORACLE_LIKE"/>
        <addToHSet item="INDB_ORACLE" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
