<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.hashdata-driver-integration</id>
    <name>HashData Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides HashData JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商： 酷克数据
<br>简介：HashData数据仓库是一个高性能、完全托管的PB级云数据仓库服务，让企业用户能够更轻松地分析海量数据。
    <br>QQ群：737639828
    <br>bug反馈：https://github.com/galaxy-sea/jetbrains-chinese-database-drivers/issues
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="HASHDATA" instance="plus.wcj.jetbrains.plugins.hashdata.HashDataDatabaseDbms.HASHDATA"/>
        <extensionFallback dbms="HASHDATA" fallbackDbms="POSTGRES"/>
        <addToHSet item="HASHDATA" set="POSTGRES_LIKE"/>
        <addToHSet item="HASHDATA" set="PSEUDO_SUPPORTED"/>

        <dbms id="HASHDATA_POSTGRES" instance="plus.wcj.jetbrains.plugins.hashdata.HashDataDatabaseDbms.HASHDATA_POSTGRES"/>
        <extensionFallback dbms="HASHDATA_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="HASHDATA_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="HASHDATA_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
