<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.greatsql-driver-integration</id>
    <name>GreatSQL Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides GreatSQL JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="GREATSQL" instance="plus.wcj.jetbrains.plugins.greatsql.GreatSQLDatabaseDbms.GREATSQL"/>
        <extensionFallback dbms="GREATSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="GREATSQL" set="MYSQL_LIKE"/>
        <addToHSet item="GREATSQL" set="PSEUDO_SUPPORTED"/>

        <dbms id="GREATSQL_MYSQL" instance="plus.wcj.jetbrains.plugins.greatsql.GreatSQLDatabaseDbms.GREATSQL_MYSQL"/>
        <extensionFallback dbms="GREATSQL_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="GREATSQL_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="GREATSQL_MYSQL" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
