<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.todis-driver-integration</id>
    <name>Todis Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides Todis JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：拓扑岭
        <br>简介：拓扑岭公司的云数据库 Todis 直击开源 Redis 的痛点，采用计算存储分离架构，不仅完全兼容 Redis 协议，而且突破了开源 Redis 的内存限制，在保证热数据驻留内存的同时，将冷数据置换入分布式存储池进行持久化存储，最大程度的降低使用成本。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="TODIS" instance="plus.wcj.jetbrains.plugins.todis.TodisDatabaseDbms.TODIS"/>
        <extensionFallback dbms="TODIS" fallbackDbms="REDIS"/>
        <addToHSet item="TODIS" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
