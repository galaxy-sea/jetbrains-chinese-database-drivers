<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.hunghudb-driver-integration</id>
    <name>HungHuDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides HungHuDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：文武信息
<br>简介：HungHuDB鸿鹄数据库是由成都文武信息技术打造的基于PostgreSQL数据库开发的数据处理平台，拥有原生的列存储技术和压缩技术。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="HUNGHUDB" instance="plus.wcj.jetbrains.plugins.hunghudb.HungHuDBDatabaseDbms.HUNGHUDB"/>
        <extensionFallback dbms="HUNGHUDB" fallbackDbms="POSTGRES"/>
        <addToHSet item="HUNGHUDB" set="POSTGRES_LIKE"/>
        <addToHSet item="HUNGHUDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="HUNGHUDB_POSTGRES" instance="plus.wcj.jetbrains.plugins.hunghudb.HungHuDBDatabaseDbms.HUNGHUDB_POSTGRES"/>
        <extensionFallback dbms="HUNGHUDB_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="HUNGHUDB_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="HUNGHUDB_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
