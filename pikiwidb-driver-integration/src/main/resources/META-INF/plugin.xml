<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.pikiwidb-driver-integration</id>
    <name>PikiwiDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides PikiwiDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="PIKIWIDB" instance="plus.wcj.jetbrains.plugins.pikiwidb.PikiwiDBDatabaseDbms.PIKIWIDB"/>
        <extensionFallback dbms="PIKIWIDB" fallbackDbms="REDIS"/>
        <addToHSet item="PIKIWIDB" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
