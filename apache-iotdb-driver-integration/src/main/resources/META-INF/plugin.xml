<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.apache-iotdb-driver-integration</id>
    <name>Apache IoTDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides Apache IoTDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="APACHE_IOTDB" instance="plus.wcj.jetbrains.plugins.apacheiotdb.ApacheIoTDBDatabaseDbms.APACHE_IOTDB"/>
        <extensionFallback dbms="APACHE_IOTDB" fallbackDbms="UNKNOWN"/>
        <addToHSet item="APACHE_IOTDB" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
