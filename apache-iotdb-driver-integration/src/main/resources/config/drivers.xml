<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="apache-iotdb" name="Apache IoTDB" icon="/icons/driversIcon.svg" dialect="GenericSQL" forced-dbms="APACHE_IOTDB" driver-class="org.apache.iotdb.jdbc.IoTDBDriver" group-with="apache-iotdb">
    <url-template name="default" template="jdbc:iotdb://{host::localhost}[:{port::6667}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="Apache IoTDB Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
</drivers>
