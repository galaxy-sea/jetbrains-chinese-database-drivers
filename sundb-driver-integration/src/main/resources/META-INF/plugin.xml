<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.sundb-driver-integration</id>
    <name>SUNDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides SUNDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="SUNDB" instance="plus.wcj.jetbrains.plugins.sundb.SUNDBDatabaseDbms.SUNDB"/>
        <extensionFallback dbms="SUNDB" fallbackDbms="UNKNOWN"/>
        <addToHSet item="SUNDB" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
