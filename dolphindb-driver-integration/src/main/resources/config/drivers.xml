<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="dolphindb" name="DolphinDB" dialect="GenericSQL" forced-dbms="DOLPHINDB" group-with="dolphindb" driver-class="com.dolphindb.jdbc.Driver">
    <url-template name="default" template="jdbc:dolphindb://{host::localhost}[:{port::8848}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="DolphinDB Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
</drivers>
