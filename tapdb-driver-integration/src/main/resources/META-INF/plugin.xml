<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.tapdb-driver-integration</id>
    <name>TapDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides TapDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：钛铂数据（Tapdata）
<br>原生JSON API支持、 信创认证、 多场景应用
<br>简介：TapDB 是一个国产化分布式文档数据库，全面兼容 MongoDB 社区版本，原生 JSON API 支持，国产化文档数据库无缝迁移，适配国产芯片鲲鹏，海光，海思, 以及麒麟等操作系统。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="TAPDB" instance="plus.wcj.jetbrains.plugins.tapdb.TapDBDatabaseDbms.TAPDB"/>
        <extensionFallback dbms="TAPDB" fallbackDbms="MONGO"/>
        <addToHSet item="TAPDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="TAPDB_MONGO" instance="plus.wcj.jetbrains.plugins.tapdb.TapDBDatabaseDbms.TAPDB_MONGO"/>
        <extensionFallback dbms="TAPDB_MONGO" fallbackDbms="MONGO"/>
        <addToHSet item="TAPDB_MONGO" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
