<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.oushudb-driver-integration</id>
    <name>OushuDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides OushuDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：偶数科技
<br>云原生、 高性能、 强兼容、 纯国产、 应用广
<br>简介：OushuDB 是一款高性能云原生数据库，由国人自主研发、符合信创标准；OushuDB通过计算存储分离架构解决了传统数据库高成本、高门槛、难维护、难拓展的问题。同时支持各大公有云和私有云。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="OUSHUDB" instance="plus.wcj.jetbrains.plugins.oushudb.OushuDBDatabaseDbms.OUSHUDB"/>
        <extensionFallback dbms="OUSHUDB" fallbackDbms="POSTGRES"/>
        <addToHSet item="OUSHUDB" set="POSTGRES_LIKE"/>
        <addToHSet item="OUSHUDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="OUSHUDB_POSTGRES" instance="plus.wcj.jetbrains.plugins.oushudb.OushuDBDatabaseDbms.OUSHUDB_POSTGRES"/>
        <extensionFallback dbms="OUSHUDB_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="OUSHUDB_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="OUSHUDB_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
