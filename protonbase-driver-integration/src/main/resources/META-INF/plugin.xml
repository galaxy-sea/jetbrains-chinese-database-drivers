<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.protonbase-driver-integration</id>
    <name>ProtonBase Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides ProtonBase JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：小质科技
<br>多云原生、 所有数据、 极简体验
<br>简介：ProtonBase 是多云原生、兼容 PostgreSQL 的分布式 Data Warebase (Data Warehouse + Database) ，在一个系统内实现了事务处理、实时数仓、数据湖分析、全文检索、以及向量检索等企业级核心数据存储和查询的需求。
    <br>QQ群：737639828
    <br>bug反馈：https://github.com/galaxy-sea/jetbrains-chinese-database-drivers/issues
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="PROTONBASE" instance="plus.wcj.jetbrains.plugins.protonbase.ProtonBaseDatabaseDbms.PROTONBASE"/>
        <extensionFallback dbms="PROTONBASE" fallbackDbms="POSTGRES"/>
        <addToHSet item="PROTONBASE" set="POSTGRES_LIKE"/>
        <addToHSet item="PROTONBASE" set="PSEUDO_SUPPORTED"/>

        <dbms id="PROTONBASE_POSTGRES" instance="plus.wcj.jetbrains.plugins.protonbase.ProtonBaseDatabaseDbms.PROTONBASE_POSTGRES"/>
        <extensionFallback dbms="PROTONBASE_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="PROTONBASE_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="PROTONBASE_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
