<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.tair-driver-integration</id>
    <name>Tair Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides Tair JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="TAIR" instance="plus.wcj.jetbrains.plugins.tair.TairDatabaseDbms.TAIR"/>
        <extensionFallback dbms="TAIR" fallbackDbms="REDIS"/>
        <addToHSet item="TAIR" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
