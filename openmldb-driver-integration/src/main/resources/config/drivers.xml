<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="openmldb" name="OpenMLDB" dialect="MySQL" forced-dbms="OPENMLDB" driver-class="com._4paradigm.openmldb.jdbc.SQLDriver" group-with="openmldb">
    <url-template name="default" template="jdbc:openmldb:///[{database}?][\?&lt;&amp;,zk={host::localhost}:{port::6181},zkPath=/openmldb,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="OpenMLDB Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
  <driver id="openmldb-mysql" name="OpenMLDB (MySQL)" forced-dbms="OPENMLDB_MYSQL" based-on="mysql.8" group-with="openmldb">
    <remarks>OpenMLDB</remarks>
  </driver>
</drivers>
