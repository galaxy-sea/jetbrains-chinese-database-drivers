<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.openmldb-driver-integration</id>
    <name>OpenMLDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides OpenMLDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="OPENMLDB" instance="plus.wcj.jetbrains.plugins.openmldb.OpenMLDBDatabaseDbms.OPENMLDB"/>
        <extensionFallback dbms="OPENMLDB" fallbackDbms="MYSQL"/>
        <addToHSet item="OPENMLDB" set="MYSQL_LIKE"/>
        <addToHSet item="OPENMLDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="OPENMLDB_MYSQL" instance="plus.wcj.jetbrains.plugins.openmldb.OpenMLDBDatabaseDbms.OPENMLDB_MYSQL"/>
        <extensionFallback dbms="OPENMLDB_MYSQL" fallbackDbms="MYSQL"/>
        <addToHSet item="OPENMLDB_MYSQL" set="MYSQL_LIKE"/>
        <addToHSet item="OPENMLDB_MYSQL" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
