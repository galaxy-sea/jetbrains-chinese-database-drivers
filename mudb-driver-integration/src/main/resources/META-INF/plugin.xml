<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.mudb-driver-integration</id>
    <name>MuDB Driver Integration</name>
    <vendor email="WeiChangJin1996@gmail.com" url="https://wcj.plus/">ChangJin Wei (魏昌进)</vendor>

    <description><![CDATA[
        Provides MuDB JDBC driver connection metadata for JetBrains IDEs.
        <br>厂商：沐融信息
<br>简介：MuDB 是北京沐融信息科技股份有限公司基于 openGauss 2.0.0 研发的企业级关系型数据库，也是 openGauss 商业发型版之一，MuDB 已通过高斯开源社区认证。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="MUDB" instance="plus.wcj.jetbrains.plugins.mudb.MuDBDatabaseDbms.MUDB"/>
        <extensionFallback dbms="MUDB" fallbackDbms="POSTGRES"/>
        <addToHSet item="MUDB" set="POSTGRES_LIKE"/>
        <addToHSet item="MUDB" set="PSEUDO_SUPPORTED"/>

        <dbms id="MUDB_POSTGRES" instance="plus.wcj.jetbrains.plugins.mudb.MuDBDatabaseDbms.MUDB_POSTGRES"/>
        <extensionFallback dbms="MUDB_POSTGRES" fallbackDbms="POSTGRES"/>
        <addToHSet item="MUDB_POSTGRES" set="POSTGRES_LIKE"/>
        <addToHSet item="MUDB_POSTGRES" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
