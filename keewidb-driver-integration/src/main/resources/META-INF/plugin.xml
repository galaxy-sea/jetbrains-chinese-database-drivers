<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.keewidb-driver-integration</id>
    <name>KeeWiDB Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides KeeWiDB JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="KEEWIDB" instance="plus.wcj.jetbrains.plugins.keewidb.KeeWiDBDatabaseDbms.KEEWIDB"/>
        <extensionFallback dbms="KEEWIDB" fallbackDbms="REDIS"/>
        <addToHSet item="KEEWIDB" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
