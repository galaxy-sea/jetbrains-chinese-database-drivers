    <url-template name="default" template="jdbc:starrocks://{host::localhost}[:{port::9030}][/{database}?][\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <artifact id="StarRocks Driver" use="true" rolling="true"/>
    <option name="auto-sync" value="true"/>
  </driver>
  <driver id="starrocks-mysql" name="StarRocks (MySQL)" icon="/icons/driversIcon.svg" forced-dbms="STARROCKS_MYSQL" based-on="mysql.8" group-with="starrocks">
    <remarks>StarRocks</remarks>
  </driver>
</drivers>
