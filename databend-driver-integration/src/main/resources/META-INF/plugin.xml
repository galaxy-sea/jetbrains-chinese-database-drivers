<idea-plugin>
    <id>plus.wcj.jetbrains.plugins.databend-driver-integration</id>
    <name>Databend Driver Integration</name>
    <vendor>plus.wcj</vendor>

    <description><![CDATA[
        Provides Databend JDBC driver connection metadata for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij.database">
        <driversConfig config="config/drivers.xml"/>
        <artifactsConfig config="config/artifacts.xml"/>
        <dbms id="DATABEND" instance="plus.wcj.jetbrains.plugins.databend.DatabendDatabaseDbms.DATABEND"/>
        <extensionFallback dbms="DATABEND" fallbackDbms="MYSQL"/>
        <addToHSet item="DATABEND" set="MYSQL_LIKE"/>
        <addToHSet item="DATABEND" set="PSEUDO_SUPPORTED"/>
    </extensions>
</idea-plugin>
